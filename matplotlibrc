# Font sizes
font.size: 7            # Base font size in points
axes.labelsize: 7       # Font size of the x and y labels
axes.titlesize: 7       # Font size of titles
xtick.labelsize: 6      # Font size of the tick labels
ytick.labelsize: 6      # Font size of the tick labels
legend.fontsize: 6      # Font size of the legend

# Font family
font.family: sans-serif # Font family ('serif', 'sans-serif', 'cursive', 'fantasy', 'monospace')
font.sans-serif: Roboto
# font.family: serif
# font.serif: Times New Roman
mathtext.fontset: cm

# Grid lines
axes.grid: True
axes.axisbelow: True
grid.linestyle: --
grid.color: k
grid.alpha: 0.5

legend.handlelength: 1.132
legend.frameon: True
legend.fancybox: False
legend.numpoints: 1
legend.handletextpad: 0.45

# Line widths
axes.linewidth: 0.5
grid.linewidth: 0.5
lines.linewidth: 1.0
lines.markersize: 3

# Set x axis
# xtick.direction: in
xtick.major.size: 2.625
xtick.major.width: 0.5
xtick.minor.size: 1.5
xtick.minor.width: 0.5
xtick.minor.visible: True
# xtick.top: True

# Set y axis
# ytick.direction: in
ytick.major.size: 2.625
ytick.major.width: 0.5
ytick.minor.size: 1.5
ytick.minor.width: 0.5
ytick.minor.visible: True
# ytick.right: True

# Save figures
# savefig.dpi: 600        # Resolution in dots per inch
savefig.format: pdf        # Format (png, pdf, svg, ps, eps, ...)
# savefig.bbox: tight
# savefig.edgecolor: black
# savefig.pad_inches: 0.001

# Colorblind friendly palette https://www.nature.com/articles/nmeth.1618
axes.prop_cycle: cycler('color', ['0072B2','D55E00','009E73','E69F00','56B4E9','F0E442','CC79A7'])

# Use truetype fonts
ps.fonttype: 42
pdf.fonttype: 42

# Use TeX
# text.usetex : True
# text.latex.preamble : \usepackage{amsmath} \usepackage{amssymb}
# text.latex.preamble : \usepackage{amsmath} \usepackage{amssymb} \usepackage{sfmath}